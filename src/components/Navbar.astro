---
import LanguagePicker from './LanguagePicker.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const leftNavItems = [
  { label: t('nav.home'), href: translatePath('/') },
  { label: t('nav.about'), href: translatePath('/nosotros') },
  { label: t('nav.news'), href: translatePath('/novedades') },
];

const rightNavItems = [
  { label: t('nav.projects'), href: translatePath('/proyectos') },
  { label: t('nav.contact'), href: translatePath('/contacto') },
  { label: t('nav.transparency'), href: translatePath('/transparencia') },
];

const currentPath = Astro.url.pathname;
---

<header x-data="{ open: false }" class="relative z-50">
  <!-- Barra azul superior -->
  <div class="bg-primary text-text-inverse min-h-6 h-auto">
    <div class="max-w-350 mx-auto px-6 py-1 flex flex-wrap items-center justify-between gap-2">
      <span class="font-sans text-xs md:text-body leading-tight md:leading-7 font-normal tracking-wide">
        En América Latina y el Caribe
      </span>
      <LanguagePicker />
    </div>
  </div>

  <!-- Navbar principal -->
  <nav class="bg-white h-24 rounded-bl-lg rounded-br-lg shadow-blue">
    <div class="max-w-350 mx-auto px-6 flex items-center justify-between h-full">
      <!-- Left menu (desktop) -->
      <ul class="hidden lg:flex items-center gap-1 list-none m-0 p-0 flex-1">
        {
          leftNavItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class={`
                    font-sans text-small md:text-body font-medium no-underline px-3 py-1.5 rounded-none
                    transition-colors duration-fast
                    ${isActive
                      ? 'bg-accent-magenta text-text-inverse'
                      : 'text-text-primary hover:bg-secondary'
                    }
                  `}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Logo centrado -->
      <a href={translatePath('/')} class="no-underline shrink-0 lg:absolute lg:left-1/2 lg:-translate-x-1/2 inline-block" aria-label={`Ciudadanía Inteligente - ${t('nav.home')}`}>
        <img
          src="/img/logo-ciudadania.svg"
          alt="Ciudadanía Inteligente"
          width="134"
          height="38"
          class="w-35 h-auto"
        />
      </a>

      <!-- Right menu (desktop) -->
      <ul class="hidden lg:flex items-center gap-1 list-none m-0 p-0 flex-1 justify-end">
        {
          rightNavItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class={`
                    font-sans text-small md:text-body font-medium no-underline px-3 py-1.5 rounded-none
                    transition-colors duration-fast
                    ${isActive
                      ? 'bg-accent-magenta text-text-inverse'
                      : 'text-text-primary hover:bg-secondary'
                    }
                  `}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="lg:hidden flex flex-col gap-1.5 p-2 bg-transparent border-none cursor-pointer ml-auto"
        @click="open = !open"
        aria-label="Toggle menu"
        :aria-expanded="open"
      >
        <span
          class="block w-6 h-0.5 bg-text-primary transition-transform duration-base origin-center"
          :class="open ? 'rotate-45 translate-y-2' : ''"
        ></span>
        <span
          class="block w-6 h-0.5 bg-text-primary transition-opacity duration-base"
          :class="open ? 'opacity-0' : ''"
        ></span>
        <span
          class="block w-6 h-0.5 bg-text-primary transition-transform duration-base origin-center"
          :class="open ? '-rotate-45 -translate-y-2' : ''"
        ></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      x-show="open"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-2"
      class="lg:hidden border-t border-secondary/20 bg-bg-default px-6 pb-4"
      style="display: none;"
    >
      <ul class="flex flex-col gap-1 list-none m-0 p-0 py-2">
        {
          [...leftNavItems, ...rightNavItems].map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  @click="open = false"
                  class={`
                    block font-sans text-body font-medium no-underline px-3 py-2 rounded-none
                    transition-colors duration-fast
                    ${isActive
                      ? 'bg-accent-magenta text-text-inverse'
                      : 'text-text-primary hover:bg-secondary'
                    }
                  `}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </nav>
</header>
