---
const leftNavItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Transparencia', href: '/transparencia' },
];

const rightNavItems = [
  { label: 'Proyectos', href: '/proyectos' },
  { label: 'Novedades', href: '/novedades' },
  { label: 'Contacto', href: '/contacto' },
];

const currentPath = Astro.url.pathname;
---

<header x-data="{ open: false }" class="relative z-50">
  <!-- Barra azul superior -->
  <div class="bg-primary text-text-inverse h-6">
    <div class="max-w-350 mx-auto px-6 py-0.5 flex items-center justify-between">
      <span class="font-sans text-body leading-7 font-normal tracking-wide">
        En america latina y el caribe
      </span>
      <div class="flex items-center gap-2 font-sans text-caption font-medium">
        <button class="bg-transparent text-text-inverse px-2 py-0.5 border-none cursor-pointer font-bold">ES</button>
        <button class="bg-transparent text-text-inverse px-2 py-0.5 border-none cursor-pointer hover:opacity-80 font-normal">EN</button>
        <button class="bg-transparent text-text-inverse px-2 py-0.5 border-none cursor-pointer hover:opacity-80 font-normal">PT</button>
      </div>
    </div>
  </div>

  <!-- Navbar principal -->
  <nav class="bg-white h-24 rounded-bl-lg rounded-br-lg shadow-blue">
    <div class="max-w-350 mx-auto px-6 flex items-center justify-between h-full">
      <!-- Left menu (desktop) -->
      <ul class="hidden lg:flex items-center gap-1 list-none m-0 p-0 flex-1">
        {
          leftNavItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class={`
                    font-sans text-small md:text-body font-medium no-underline px-3 py-1.5 rounded-none
                    transition-colors duration-fast
                    ${isActive
                      ? 'bg-accent-magenta text-text-inverse'
                      : 'text-text-primary hover:bg-secondary hover:text-neutral-dark'
                    }
                  `}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Logo centrado -->
      <a href="/" class="no-underline shrink-0 lg:absolute lg:left-1/2 lg:-translate-x-1/2 inline-block" aria-label="Ciudadanía Inteligente - Inicio">
        <img
          src="/img/logo-ciudadania.svg"
          alt="Ciudadanía Inteligente"
          width="134"
          height="38"
          class="w-35 h-auto"
        />
      </a>

      <!-- Right menu (desktop) -->
      <ul class="hidden lg:flex items-center gap-1 list-none m-0 p-0 flex-1 justify-end">
        {
          rightNavItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class={`
                    font-sans text-small md:text-body font-medium no-underline px-3 py-1.5 rounded-none
                    transition-colors duration-fast
                    ${isActive
                      ? 'bg-accent-magenta text-text-inverse'
                      : 'text-text-primary hover:bg-secondary hover:text-neutral-dark'
                    }
                  `}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="lg:hidden flex flex-col gap-1.5 p-2 bg-transparent border-none cursor-pointer ml-auto"
        @click="open = !open"
        aria-label="Toggle menu"
        :aria-expanded="open"
      >
        <span
          class="block w-6 h-0.5 bg-text-primary transition-transform duration-base origin-center"
          :class="open ? 'rotate-45 translate-y-2' : ''"
        ></span>
        <span
          class="block w-6 h-0.5 bg-text-primary transition-opacity duration-base"
          :class="open ? 'opacity-0' : ''"
        ></span>
        <span
          class="block w-6 h-0.5 bg-text-primary transition-transform duration-base origin-center"
          :class="open ? '-rotate-45 -translate-y-2' : ''"
        ></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      x-show="open"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-2"
      class="lg:hidden border-t border-secondary/20 bg-bg-default px-6 pb-4"
      style="display: none;"
    >
      <ul class="flex flex-col gap-1 list-none m-0 p-0 py-2">
        {
          [...leftNavItems, ...rightNavItems].map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  @click="open = false"
                  class={`
                    block font-sans text-body font-medium no-underline px-3 py-2 rounded-none
                    transition-colors duration-fast
                    ${isActive
                      ? 'bg-accent-magenta text-text-inverse'
                      : 'text-text-primary hover:bg-secondary hover:text-neutral-dark'
                    }
                  `}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </nav>
</header>
