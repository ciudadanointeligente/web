---
interface Props {
  name: string;
  position: string;
  photo: string;
  description: string;
  email?: string;
  twitter?: string;
  linkedin?: string;
  instagram?: string;
  github?: string;
}

const {
  name,
  position,
  photo,
  description,
  email,
  twitter,
  linkedin,
  instagram,
  github,
} = Astro.props;

const modalId = `person-modal-${name
  .toLowerCase()
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-|-$/g, '')}`;
---

<!-- card de persona -->
<div
  role="button"
  tabindex="0"
  class="w-full max-w-sm h-72 relative mx-auto cursor-pointer"
  onclick={`document.getElementById('${modalId}').showModal()`}
  onkeydown={`if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); document.getElementById('${modalId}').showModal(); }`}
  aria-label={`Ver perfil de ${name}`}
>
  <div
    class="absolute bottom-0 left-0 w-full h-40 bg-white rounded-[28.60px] shadow-card pt-12 pb-4 px-2.5 inline-flex justify-center items-center"
  >
    <div class="text-center">
      <span class="font-['Work_Sans'] text-fuchsia-600 text-2xl font-normal block">
        {name}
      </span>
      <span class="font-['Work_Sans'] text-black text-xl font-medium block">
        {position}
      </span>
    </div>
  </div>
  {photo ? (
    <img
      src={photo}
      alt={`Foto de ${name}`}
      class="absolute top-0 left-1/2 -translate-x-1/2 size-48 rounded-full shadow-[0px_3.8px_3.8px_0px_rgba(0,0,0,0.30),0px_7.6px_11.4px_5.7px_rgba(0,0,0,0.15)] object-cover"
      loading="lazy"
    />
  ) : (
    <div class="absolute top-0 left-1/2 -translate-x-1/2 size-48 rounded-full bg-neutral-dark shadow-[0px_3.8px_3.8px_0px_rgba(0,0,0,0.30),0px_7.6px_11.4px_5.7px_rgba(0,0,0,0.15)] flex items-center justify-center">
      <span class="text-text-inverse/40 text-sm">Foto</span>
    </div>
  )}
</div>

<!-- modal de persona -->
<dialog
  id={modalId}
  class="m-auto max-w-2xl w-[calc(100%-2rem)] rounded-2xl shadow-lg p-0 bg-transparent border-none"
>
  <div class="bg-white rounded-2xl overflow-hidden relative">
    <form method="dialog" class="absolute right-2 top-2 z-10">
      <button
        type="submit"
        class="w-8 h-8 rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-text-inverse transition-colors duration-fast flex items-center justify-center border-none cursor-pointer"
        aria-label="Cerrar"
      >
        ✕
      </button>
    </form>
    <div class="flex flex-col md:flex-row">
      <div class="md:w-1/3 bg-bg-gray flex items-center justify-center p-4">
        {photo ? (
          <img
            src={photo}
            alt={`Foto de ${name}`}
            class="w-48 h-48 md:w-full md:h-auto object-cover rounded-full md:rounded-md"
          />
        ) : (
          <div class="w-48 h-48 rounded-full bg-neutral-dark flex items-center justify-center">
            <span class="text-text-inverse/40 text-sm">Foto</span>
          </div>
        )}
      </div>
      <div class="md:w-2/3 py-6 px-6">
        <h3 class="font-['Work_Sans'] text-fuchsia-600 text-2xl font-normal mb-1">
          {name}
        </h3>
        <p class="font-['Work_Sans'] text-black text-xl font-medium mb-4">
          {position}
        </p>
        <p class="font-['Work_Sans'] text-text-body text-base font-normal leading-body mb-6">
          {description}
        </p>
        <div class="flex flex-wrap gap-3">
          {email && (
            <a
              href={`mailto:${email}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-bg-gray text-primary hover:bg-primary hover:text-text-inverse transition-colors duration-fast flex items-center justify-center no-underline"
              aria-label={`Enviar correo a ${name}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </a>
          )}
          {twitter && (
            <a
              href={twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-bg-gray text-primary hover:bg-primary hover:text-text-inverse transition-colors duration-fast flex items-center justify-center no-underline"
              aria-label={`Twitter de ${name}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          )}
          {linkedin && (
            <a
              href={linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-bg-gray text-primary hover:bg-primary hover:text-text-inverse transition-colors duration-fast flex items-center justify-center no-underline"
              aria-label={`LinkedIn de ${name}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          )}
          {instagram && (
            <a
              href={instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-bg-gray text-primary hover:bg-primary hover:text-text-inverse transition-colors duration-fast flex items-center justify-center no-underline"
              aria-label={`Instagram de ${name}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          )}
          {github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-bg-gray text-primary hover:bg-primary hover:text-text-inverse transition-colors duration-fast flex items-center justify-center no-underline"
              aria-label={`GitHub de ${name}`}
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</dialog>

<style>
  dialog {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  dialog[open] {
    opacity: 1;
    transform: scale(1);
  }

  @starting-style {
    dialog[open] {
      opacity: 0;
      transform: scale(0.95);
    }
  }

  dialog::backdrop {
    background-color: rgba(37, 41, 67, 0);
    transition: background-color 0.3s ease;
  }

  dialog[open]::backdrop {
    background-color: rgba(37, 41, 67, 0.7);
  }

  @starting-style {
    dialog[open]::backdrop {
      background-color: rgba(37, 41, 67, 0);
    }
  }
</style>
