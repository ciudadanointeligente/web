  <div class="max-w-[1400px] mx-auto px-6 py-12 md:py-16 relative">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-sans font-bold text-h4 md:text-h3 leading-headings mb-6">
        Súmate a nuestro Newsletter
      </h2>
      <form class="flex flex-col sm:flex-row gap-3" action="#" method="POST">
        <input
          type="email"
          placeholder="Escribe tu correo aquí"
          required
          class="flex-1 font-sans text-body font-regular text-text-body bg-neutral-white rounded-pill px-5 py-3 placeholder:text-neutral-dark/50 focus:outline-none focus:ring-2 focus:ring-accent-magenta transition-all duration-fast"
        />
        <button
          type="submit"
          class="font-sans text-body font-bold text-text-primary bg-neutral-white rounded-pill px-6 py-3 border-none cursor-pointer hover:bg-accent-magenta hover:text-text-inverse transition-all duration-fast"
        >
          SUSCRÍBETE
        </button>
      </form>
    </div>
  </div>
</section>
