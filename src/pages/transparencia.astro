---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const memorias = (await getCollection('memorias')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
const documentos = (await getCollection('documentos')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
);
---

<Layout
  title="Transparencia | Ciudadanía Inteligente"
  description="Creemos que la transparencia fortalece la democracia. Ponemos a disposición información clara sobre cómo nos financiamos y qué resultados logramos."
>
  <Navbar />

  <main>
    <PageHero
      title="Transparencia"
      description={`<span class="text-white text-2xl font-bold font-['Work_Sans']">Creemos que la transparencia fortalece la democracia.</span><span class="text-white text-2xl font-medium font-['Work_Sans']"></span> <span class="text-[#96f67d] text-2xl font-medium font-['Work_Sans']">Por eso ponemos a disposición de todas las personas información clara sobre cómo nos financiamos, quiénes apoyan nuestro trabajo y qué resultados logramos cada año.</span>`}
      breadcrumb={[
        { label: 'Inicio', href: '/' },
        { label: 'Transparencia' },
      ]}
    />

    <!-- Financing -->
    <section class="relative py-16 md:py-20">
      <div class="max-w-250 mx-auto px-6 relative">
        <div class="flex flex-col md:flex-row gap-6 md:gap-16 items-start">
          <span
            class="inline-block shrink-0 font-sans font-bold text-h6 md:text-h5 text-text-inverse uppercase tracking-wide mb-0 bg-accent-magenta px-4 py-2 text-nowrap"
          >
            ¿Cómo nos financiamos?
          </span>
          <p class="flex-1 font-sans text-body text-text-body leading-body">
            Nos financiamos principalmente a través de la postulación de proyectos a entidades internacionales y organismos de cooperación. También generamos acciones de cambio a través de alianzas con instituciones públicas y otras organizaciones de sociedad civil.
          </p>
        </div>
      </div>
    </section>

    <!-- Annual Reports -->
    <section class="relative py-16 md:py-20">
      <div class="max-w-250 mx-auto px-6 relative">
        <h2 class="font-sans font-black text-h2 md:text-h1 text-text-primary uppercase tracking-wide text-center mb-2">
          Reportes Anuales
        </h2>
        <p class="font-sans text-body text-text-body text-center mb-10">
          Accede a nuestras memorias y otros documentos importantes de nuestra gestión.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h3 class="inline-block font-sans font-bold text-h6 md:text-h5 text-text-inverse uppercase tracking-wide mb-4 bg-accent-magenta px-4 py-2">
              Memorias
            </h3>
            <ul class="list-disc list-inside space-y-2 font-sans text-body text-text-primary">
              {memorias.map((memoria) => {
                const href = memoria.data.link || memoria.data.descarga || '#';
                return (
                  <li>
                    <a
                      href={href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-text-primary underline hover:text-accent-magenta transition-colors"
                    >
                      {memoria.data.nombre}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
          <div>
            <h3 class="inline-block font-sans font-bold text-h6 md:text-h5 text-text-inverse uppercase tracking-wide mb-4 bg-accent-magenta px-4 py-2">
              Protocolos y funcionamiento
            </h3>
            <ul class="list-disc list-inside space-y-2 font-sans text-body text-text-primary">
              {documentos.map((documento) => {
                const href = documento.data.link || documento.data.descarga || '#';
                return (
                  <li>
                    <a
                      href={href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-text-primary underline hover:text-accent-magenta transition-colors"
                    >
                      {documento.data.nombre}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Supporters -->
    <section class="relative py-16 md:py-20">
      <div class="max-w-250 mx-auto px-6 relative">
        <h2 class="font-sans font-black text-h2 md:text-h1 text-text-primary uppercase tracking-wide text-center mb-10">
          Quiénes apoyan nuestro trabajo
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-x-8 gap-y-10 items-center">
          {[
            { name: 'Unión Europea', file: 'logo-ue.webp' },
            { name: 'Packard Foundation', file: 'logo-packard.webp' },
            { name: 'Friedrich Ebert Stiftung', file: 'logo-fes.webp' },
            { name: 'UNDEF', file: 'logo-undef.webp' },
            { name: 'OXFAM', file: 'logo-oxfam.webp' },
            { name: 'Luminate', file: 'logo-luminate.webp' },
            { name: 'Open Society Foundations', file: 'logo-open-society.webp' },
            { name: 'IDRC CRDI', file: 'logo-idrc.webp' },
            { name: 'NED', file: 'logo-ned.webp' },
            { name: 'Avina', file: 'logo-avina.webp' },
            { name: 'AECID', file: 'logo-aecid.webp' },
            { name: 'Karibu Foundation', file: 'logo-karibu.webp' },
          ].map((org) => (
            <div class="flex items-center justify-center h-16 px-2" title={org.name}>
              <img
                src={`/img/${org.file}`}
                alt={org.name}
                loading="lazy"
                class="max-h-12 w-auto max-w-full object-contain"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Financial Transparency -->
    <section class="relative py-16 md:py-20">
      <div class="max-w-250 mx-auto px-6 relative">
        <h2 class="font-sans font-black text-h2 md:text-h1 text-text-primary uppercase tracking-wide text-center mb-6">
          Transparencia Financiera
        </h2>

        <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
          <span class="font-sans text-body font-bold text-text-primary">Filtrar por:</span>
          <select class="font-sans text-body font-bold text-text-primary bg-accent-green border-none rounded-md px-4 py-2 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary">
            <option>Año</option>
          </select>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <Newsletter decorated />
  </main>

  <Footer />
</Layout>
