---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Contacto | Ciudadanía Inteligente"
  description="¿Quieres sumarte, colaborar o escribirnos? Aquí tienes todas las formas de ponerte en contacto con Ciudadanía Inteligente."
>
  <div class="bg-primary">
    <Navbar />
  </div>
  <main>
    <PageHero
      title="Contacto"
      description={`<span class="text-white text-2xl font-bold font-['Work_Sans']">¿Quieres sumarte, colaborar o escribirnos?</span> <span class="text-white text-2xl font-medium font-['Work_Sans']"></span><span class="text-[#96f67d] text-2xl font-medium font-['Work_Sans']">Aquí tienes todas las formas de ponerte en contacto con Ciudadanía Inteligente.</span>`}
      breadcrumb={[
        { label: 'Inicio', href: '/' },
        { label: 'Contacto' },
      ]}
    />

    <!-- Contact CTA -->
    <section class="relative py-8 md:py-10">
      <div class="max-w-200 mx-auto px-6 relative text-center">
        <h2 class="font-sans font-black text-[40px] text-text-primary uppercase tracking-tight mb-4">
          ¿Quieres sumarte, colaborar o escribirnos?
        </h2>
        <p class="font-['Work_Sans'] text-black text-xl font-normal leading-[29.60px] mb-12">
          Aquí tienes todas las formas de ponerte en contacto con Ciudadanía Inteligente:
        </p>
      </div>
    </section>

    <!-- Volunteer -->
    <section class="relative py-8 md:py-10">
      <div class="max-w-250 mx-auto px-6 relative">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <a
              href="#"
              class="inline-block shrink-0 font-sans font-bold text-h6 md:text-h5 text-text-inverse uppercase tracking-wide mb-0 bg-accent-magenta px-4 py-2 text-center"
            >
              Voluntariado y pasantías
            </a>
          </div>
          <div>
            <p class="font-['Work_Sans'] text-black text-xl font-normal leading-[29.60px] mb-4">
              Sé parte de nuestro equipo y aporta a la transformación democrática desde adentro.
            </p>
            <a
              href="#"
              class="inline-block font-sans text-[18.81px] font-bold uppercase tracking-wider text-text-inverse bg-primary rounded-pill px-8 py-3 no-underline hover:bg-accent-magenta transition-all duration-fast"
            >
              POSTULA AQUÍ
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Write Us -->
    <section class="relative py-8 md:py-10">
      <div class="max-w-200 mx-auto px-6 relative text-center">
        <h2 class="font-sans font-bold text-h3 text-accent-magenta mb-4">
          Escríbenos
        </h2>
        <p class="font-['Work_Sans'] text-black text-xl font-normal leading-[29.60px] mb-2">
          ¿Tienes dudas, propuestas o ideas para colaborar?
        </p>
        <p class="font-['Work_Sans'] text-black text-xl font-normal leading-[29.60px]">
          Escríbenos a <a href="mailto:info@ciudadaniai.org" class="text-text-primary font-bold no-underline hover:text-accent-magenta transition-colors">info@ciudadaniai.org</a>
        </p>
      </div>
    </section>

    <!-- Newsletter -->
    <Newsletter decorated />
  </main>

  <Footer />
</Layout>
