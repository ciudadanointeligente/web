---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('proyectos');
const homeProjects = allProjects
  .filter((project) => project.data.home)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allPosts = await getCollection('posts');
const homePosts = allPosts
  .filter((post) => post.data.showOnHome)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout
  title="Inicio | Ciudadanía Inteligente"
  description="Hacemos de la democracia una experiencia compartida, justa y transformadora."
>
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-24 md:pt-36 pb-20 md:pb-72">
      <div class="max-w-350 mx-auto px-6 relative">
        <div class="max-w-4xl mx-auto text-center">
          <p class="font-sans font-bold text-h6 md:text-h5 lg:text-h4 text-text-primary mb-2">
            Hacemos de la
          </p>
          <h1 class="font-sans font-black text-[3rem] md:text-[6rem] lg:text-[8rem] leading-[0.9] text-text-primary uppercase tracking-tight">
            Democracia
          </h1>
          <p class="font-sans font-bold text-h6 md:text-h5 lg:text-h4 text-text-primary leading-headings mt-2">
            una experiencia compartida, justa y transformadora
          </p>
        </div>
      </div>
    </section>

    <!-- About Section (Blue) -->
    <section class="bg-primary text-text-inverse relative overflow-hidden md:h-175">
      <!-- Mapa de Latinoamérica -->
      <div class="absolute right-0 top-0 bottom-0 w-1/2 md:w-2/5 lg:w-1/3 pointer-events-none flex items-center justify-end opacity-30 md:opacity-100">
        <img
          src="/img/mapa.webp"
          alt=""
          aria-hidden="true"
          width="665"
          height="892"
          class="h-full w-auto max-w-none"
        />
      </div>

      <div class="max-w-350 mx-auto px-6 relative z-10 flex items-center h-full py-12 md:py-0">
        <div class="max-w-2xl">
          <p class="font-sans text-h5 md:text-h4 font-medium leading-body">
            Trabajamos en América Latina y el Caribe desarrollando herramientas y estrategias para fortalecer <span class="text-accent-green font-bold">la participación ciudadana</span>, <span class="text-accent-green font-bold">la transparencia</span> y <span class="text-accent-green font-bold">la incidencia pública</span>.
          </p>
          <a
            href="/nosotros"
            class="inline-block mt-6 font-sans text-caption font-bold uppercase tracking-wider text-text-primary bg-neutral-white rounded-pill px-6 py-3 no-underline hover:bg-accent-magenta hover:text-text-inverse transition-all duration-fast"
          >
            NOSOTROS
          </a>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="relative pt-20 md:pt-48 pb-8 md:pb-24">
      <div class="max-w-350 mx-auto px-6 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary leading-headings uppercase tracking-wide text-center mb-10">
          Nuestros Proyectos
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">

          {homeProjects
            
            .map((proyecto) => (
              <a
                href="/proyectos"
                class="aspect-video flex items-center justify-center no-underline group overflow-hidden relative bg-primary"
              >
                {proyecto.data.imagen && (
                  <img
                    src={proyecto.data.imagen}
                    alt={proyecto.data.nombre}
                    class="absolute inset-0 w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-fast"
                    loading="lazy"
                  />
                )}
              </a>
            ))}
        </div>

        <div class="text-center mt-10">
          <a
            href="/proyectos"
            class="inline-block font-sans text-caption font-bold uppercase tracking-wider text-text-inverse bg-primary rounded-pill px-8 py-3 no-underline hover:bg-accent-magenta transition-all duration-fast"
          >
            VER TODOS LOS PROYECTOS
          </a>
        </div>
      </div>
    </section>

    <!-- News Section -->
    <section class="relative pt-8 md:pt-24 pb-16 md:pb-24">
      <div class="max-w-350 mx-auto px-6 relative">
        <p class="font-sans font-medium text-body text-text-primary uppercase tracking-wide text-center mb-2">
          Revisa nuestras
        </p>
        <h2 class="font-sans font-extrabold text-h2 text-text-primary leading-headings uppercase tracking-wide text-center mb-10">
          Últimas Novedades
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {homePosts.map((post) => (
            <article class="bg-bg-gray rounded-lg overflow-hidden flex flex-col">
              <a href={`/posts/${post.id.replace(/\.mdoc$/, '')}`} class="block aspect-4/3 bg-neutral-dark relative overflow-hidden">
                {post.data.imagepost ? (
                  <img
                    src={post.data.imagepost}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="absolute inset-0 flex items-center justify-center text-text-inverse/30 text-sm">Imagen</span>
                )}
              </a>
              <div class="p-5 flex flex-col grow">
                <div class="mb-5">
                  <span class="inline font-sans text-sm font-medium uppercase tracking-wider text-text-primary bg-sky-300 px-2 py-0.5">
                    {post.data.category || 'Actualidad'}
                  </span>
                </div>
              <h3 class="font-sans font-bold text-[20px] text-text-primary leading-tight uppercase mb-5 grow">
                  {post.data.title}
                </h3>
                <a href={`/posts/${post.id.replace(/\.mdoc$/, '')}`} class="font-sans text-base font-bold  text-fuchsia-600 underline uppercase">
                  Leer artículo
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center mt-10">
          <a
            href="/novedades"
            class="inline-block font-sans text-caption font-bold uppercase tracking-wider text-text-inverse bg-primary rounded-pill px-8 py-3 no-underline hover:bg-accent-magenta transition-all duration-fast"
          >
            VER TODAS LAS NOVEDADES
          </a>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div class="mt-2 md:mt-6">
      <Newsletter />
    </div>
  </main>

  <Footer />
</Layout>
