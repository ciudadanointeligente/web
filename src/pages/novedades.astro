---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout
  title="Novedades | Ciudadanía Inteligente"
  description="Conoce nuestras investigaciones, manuales, columnas y boletines."
>
  <Navbar />

  <main>
    <PageHero
      title="Novedades"
      description={`<span class="font-['Work_Sans'] text-white text-2xl font-bold">Conoce nuestras investigaciones, manuales, columnas y boletines</span><span class="font-['Work_Sans'] text-lime-300 text-2xl font-medium"> que analizan y proponen caminos para una democracia más participativa, justa y sostenible.</span>`}
      breadcrumb={[
        { label: 'Inicio', href: '/' },
        { label: 'Novedades' },
      ]}
    />

    <!-- News Grid -->
    <section class="relative py-16 md:py-20">
      <div class="max-w-300 mx-auto px-6 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary uppercase tracking-wide text-center mb-2">
          Nuestras Noticias
        </h2>

        <!-- Filters -->
        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
          <span class="font-sans text-body font-bold text-black">Filtrar por:</span>
          <select class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option>Producto</option>
          </select>
          <select class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option>Temática</option>
          </select>
        </div>

        <!-- News Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post) => (
            <article class="bg-bg-gray rounded-lg overflow-hidden flex flex-col">
              <a href={`/posts/${post.id.replace(/\.mdoc$/, '')}`} class="block aspect-4/3 bg-neutral-dark relative overflow-hidden">
                {post.data.imagepost ? (
                  <img
                    src={post.data.imagepost}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="absolute inset-0 flex items-center justify-center text-text-inverse/30 text-sm">Imagen</span>
                )}
              </a>
              <div class="p-5 flex flex-col grow">
                <div class="mb-5">
                  <span class="inline font-sans text-sm font-medium uppercase tracking-wider text-text-primary bg-sky-300 px-2 py-0.5">
                    {post.data.category || 'Actualidad'}
                  </span>
                </div>
                <h3 class="font-sans font-bold text-[20px] text-text-primary leading-tight uppercase mb-5 grow">
                  {post.data.title}
                </h3>
                <a href={`/posts/${post.id.replace(/\.mdoc$/, '')}`} class="font-sans text-base font-bold text-fuchsia-600 underline uppercase">
                  Leer artículo
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <Newsletter />
  </main>

  <Footer />
</Layout>
