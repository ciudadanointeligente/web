---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const proyectos = (await getCollection('proyectos')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout
  title="Proyectos | Ciudadanía Inteligente"
  description="Impulsamos proyectos que abren caminos para una democracia más justa y participativa."
>
  <Navbar />

  <main>
    <PageHero
      title="Proyectos"
      description="Impulsamos proyectos que abren caminos para una democracia más justa y participativa. Lo hacemos con comunidades y organizaciones, combinando innovación, trabajo territorial y colaboración regional."
      breadcrumb={[
        { label: 'Inicio', href: '/' },
        { label: 'Proyectos' },
      ]}
    />

    <!-- Projects Grid -->
    <section class="relative py-16 md:py-20">
      <div class="max-w-[1200px] mx-auto px-6 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary uppercase tracking-wide text-center mb-2">
          Nuestros Proyectos
        </h2>

        <!-- Filters -->
        <div class="flex flex-wrap items-center justify-center gap-4 mb-10">
          <span class="font-sans text-body font-bold text-text-primary">Filtrar por:</span>
          <select class="font-sans text-body bg-bg-cream border border-primary/20 rounded-md px-4 py-2 cursor-pointer">
            <option>Temática</option>
          </select>
          <select class="font-sans text-body bg-bg-cream border border-primary/20 rounded-md px-4 py-2 cursor-pointer">
            <option>Región</option>
          </select>
          <select class="font-sans text-body bg-bg-cream border border-primary/20 rounded-md px-4 py-2 cursor-pointer">
            <option>Estatus</option>
          </select>
        </div>

        <!-- Projects -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
          {proyectos.map((proyecto) => (
            <a
              href={proyecto.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="aspect-square relative flex items-center justify-center overflow-hidden group no-underline bg-primary"
            >
              {proyecto.data.imagen && (
                <img
                  src={proyecto.data.imagen}
                  alt={proyecto.data.nombre}
                  class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 transition-opacity duration-fast"
                  loading="lazy"
                />
              )}
              <span class="relative font-sans font-bold text-h4 text-text-inverse text-center px-4 uppercase tracking-wide">
                {proyecto.data.nombre}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <Newsletter />
  </main>

  <Footer />
</Layout>
