---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import PageHero from '../components/PageHero.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { getCollection } from 'astro:content';

const proyectos = (await getCollection('proyectos')).sort(
  (a, b) => a.data.order - b.data.order,
);

const categorias = Array.from(
  new Set(proyectos.flatMap((p) => p.data.categorias)),
).sort();

const regiones = Array.from(
  new Set(proyectos.map((p) => p.data.alcance)),
).sort();

const estatusList = ['Actual', 'Pasado'];
---

<Layout
  title="Proyectos | Ciudadanía Inteligente"
  description="Impulsamos proyectos que abren caminos para una democracia más justa y participativa."
>
  <div class="bg-primary">
    <Navbar />
  </div>
  <main>
    <PageHero
      title="Proyectos"
      description={`<span class="font-['Work_Sans'] text-white text-2xl font-bold">Impulsamos proyectos que abren caminos para una democracia más justa y participativa.</span> <span class="font-['Work_Sans'] text-lime-300 text-2xl font-medium">Con comunidades y organizaciones, combinando innovación, trabajo territorial y colaboración regional.</span>`}
      breadcrumb={[
        { label: 'Inicio', href: '/' },
        { label: 'Proyectos' },
      ]}
    />

    <!-- Projects Grid -->
    <section id="projects-section" class="relative py-16 md:py-20">
      <div class="mx-auto px-6 md:mx-0 md:px-0 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary uppercase tracking-wide text-center mb-2 md:mb-8">
          Nuestros Proyectos
        </h2>

        <!-- Filters -->
        <div class="flex flex-wrap items-center justify-center gap-4 mb-10 md:mb-16">
          <span class="text-text-primary text-xl font-bold font-['Work_Sans']">Filtrar por:</span>
          <select data-filter="tema" class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option value="">Temática</option>
            {categorias.map((categoria) => (
            <option value={categoria}>{categoria}</option>
            ))}
          </select>
          <select data-filter="region" class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option value="">Región</option>
            {regiones.map((region) => (
            <option value={region}>{region}</option>
            ))}
          </select>
          <select data-filter="estatus" class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option value="">Estatus</option>
            {estatusList.map((estatus) => (
            <option value={estatus}>{estatus}</option>
            ))}
          </select>
        </div>

        <!-- Projects -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
          {proyectos.map((proyecto) => (
          <ProjectModal
            nombre={proyecto.data.nombre}
            descripcion={proyecto.data.descripcion}
            imagen={proyecto.data.imagen}
            link={proyecto.data.link}
            categorias={proyecto.data.categorias}
            alcance={proyecto.data.alcance}
            status={proyecto.data.status}
            order={proyecto.data.order}
          />
          ))}
        </div>
      </div>
    </section>

    <script is:inline>
    function initProjectFilters() {
      const section = document.getElementById('projects-section');
      if (!section) return;

      const temaSelect = section.querySelector('select[data-filter=tema]');
      const regionSelect = section.querySelector('select[data-filter=region]');
      const estatusSelect = section.querySelector('select[data-filter=estatus]');
      const cards = section.querySelectorAll('[data-project-card]');

      if (!temaSelect || !regionSelect || !estatusSelect) return;

      function filterProjects() {
        const tema = temaSelect.value;
        const region = regionSelect.value;
        const estatus = estatusSelect.value;

        cards.forEach((card) => {
          const categorias = JSON.parse(card.dataset.categorias || '[]');
          const cardRegion = card.dataset.alcance;
          const cardStatus = card.dataset.status;

          const matchTema = !tema || categorias.includes(tema);
          const matchRegion = !region || cardRegion === region;
          const matchEstatus = !estatus || cardStatus === estatus;
          const shouldShow = matchTema && matchRegion && matchEstatus;

          if (shouldShow) {
            if (card.style.display === 'none') {
              card.style.display = '';
              card.classList.add('filter-hidden');
              void card.offsetWidth;
              card.classList.remove('filter-hidden');
            }
          } else {
            card.style.display = 'none';
            card.classList.add('filter-hidden');
          }
        });
      }

      temaSelect.addEventListener('change', filterProjects);
      regionSelect.addEventListener('change', filterProjects);
      estatusSelect.addEventListener('change', filterProjects);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProjectFilters);
    } else {
      initProjectFilters();
    }

    document.addEventListener('astro:page-load', initProjectFilters);
    </script>

    <!-- Newsletter -->
    <Newsletter decorated />
  </main>

  <Footer />
</Layout>

<style is:global>
#projects-section [data-project-card] {
  transition: opacity 250ms ease, transform 250ms ease;
}

#projects-section [data-project-card].filter-hidden {
  opacity: 0;
  transform: translateY(12px);
}
</style>
