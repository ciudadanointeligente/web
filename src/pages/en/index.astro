---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

const t = useTranslations('en');
const translatePath = useTranslatedPath('en');

const allProjects = await getCollection('proyectosEn');
const homeProjects = allProjects
  .filter((project) => project.data.home)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allPosts = await getCollection('posts');
const homePosts = allPosts
  .filter((post) => post.data.showOnHome)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout
  title="Home | Ciudadanía Inteligente"
  description="We make democracy a shared, fair, and transformative experience."
>
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-24 md:pt-36 pb-20 md:pb-72">
      <div class="max-w-350 mx-auto px-6 relative">
        <div class="max-w-4xl mx-auto flex flex-col items-center">
          <p class="font-sans font-bold text-h6 md:text-h5 lg:text-[3rem] text-text-primary mb-2">
            We make
          </p>
          <h1 class="font-sans font-black text-[3rem] md:text-[6rem] lg:text-[12rem] leading-[0.9] text-text-primary uppercase tracking-tight">
            Democracy
          </h1>
          <p class="font-sans font-bold text-h6 md:text-h5 lg:text-[3rem] text-text-primary leading-headings mt-2 md:text-nowrap">
            a shared, fair, and transformative experience
          </p>
        </div>
      </div>
    </section>

    <!-- About Section (Blue) -->
    <section class="bg-primary text-text-inverse relative md:h-175">
      <!-- Corner/border images -->
      <img
        src="/img/manobordeizquierda.webp"
        alt=""
        aria-hidden="true"
        class="absolute top-0 left-0 -translate-y-1/2 w-32 md:w-48 lg:w-60 pointer-events-none"
      />
      <img
        src="/img/manossobrebarraazulmapa.webp"
        alt=""
        aria-hidden="true"
        class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-full w-70 md:w-125 lg:w-192.5 h-21.25 md:h-37.5 lg:h-57.5 pointer-events-none"
      />
      <img
        src="/img/manobordederecho.webp"
        alt=""
        aria-hidden="true"
        class="absolute top-0 right-0 -translate-y-1/2 w-28 md:w-44 lg:w-56 pointer-events-none"
      />
      <img
        src="/img/justiciabordeizquierdo.webp"
        alt=""
        aria-hidden="true"
        class="absolute bottom-0 left-0 translate-y-1/2 w-32 md:w-48 lg:w-60 pointer-events-none"
      />
      <img
        src="/img/piezabordederecho.webp"
        alt=""
        aria-hidden="true"
        class="absolute bottom-0 right-0 translate-y-1/2 w-32 md:w-48 lg:w-60 pointer-events-none"
      />

      <!-- Mapa de Latinoamérica -->
      <div class="absolute right-0 top-0 bottom-0 w-1/2 md:w-2/5 lg:w-1/3 pointer-events-none flex items-center justify-end opacity-30 md:opacity-100">
        <img
          src="/img/mapa.webp"
          alt=""
          aria-hidden="true"
          width="665"
          height="892"
          class="h-full w-auto max-w-none"
        />
      </div>

      <div class="max-w-350 mx-auto md:mx-24 lg:mx-32 px-6 relative z-10 flex items-center md:h-175 py-12 md:py-0">
        <div class="max-w-4xl text-left">
          <p class="font-sans text-h5 md:text-h4 font-medium leading-relaxed">
            We work in Latin America and the Caribbean developing tools and strategies to strengthen <span class="text-accent-green font-bold">citizen participation</span>, <span class="text-accent-green font-bold">transparency</span>, and <span class="text-accent-green font-bold">public advocacy</span>.
          </p>
          <a
            href={translatePath('/nosotros')}
            class="inline-block mt-6 font-sans text-xl font-bold uppercase tracking-wider text-text-primary bg-neutral-white rounded-pill px-6 py-3 no-underline hover:bg-accent-magenta hover:text-text-inverse transition-all duration-fast"
          >
            ABOUT US
          </a>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="relative pt-20 md:pt-48 pb-8 md:pb-24">
      <div class="mx-auto px-6 md:px-0 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary leading-headings uppercase tracking-wide text-center mb-10">
          Our Projects
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">

          {homeProjects
            
            .map((proyecto) => (
              <a
                href={translatePath('/proyectos')}
                class="aspect-video flex items-center justify-center no-underline group overflow-hidden relative bg-primary"
              >
                {proyecto.data.imagen && (
                  <img
                    src={proyecto.data.imagen}
                    alt={proyecto.data.nombre}
                    class="absolute inset-0 w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-fast"
                    loading="lazy"
                  />
                )}
              </a>
            ))}
        </div>

        <div class="text-center mt-10">
          <a
            href={translatePath('/proyectos')}
            class="inline-block font-sans text-caption font-bold uppercase tracking-wider text-text-inverse bg-primary rounded-pill px-8 py-3 no-underline hover:bg-accent-magenta transition-all duration-fast"
          >
            VIEW ALL PROJECTS
          </a>
        </div>
      </div>
    </section>

    <!-- News Section -->
    <section class="relative pt-8 md:pt-24 pb-16 md:pb-24">
      <div class="max-w-350 mx-auto px-6 relative">
        <p class="font-sans font-medium text-body text-text-primary uppercase tracking-wide text-center mb-2">
          Check out our
        </p>
        <h2 class="font-sans font-extrabold text-h2 text-text-primary leading-headings uppercase tracking-wide text-center mb-10">
          Latest News
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {homePosts.map((post) => (
            <article class="bg-bg-gray rounded-lg overflow-hidden flex flex-col">
              <a href={`/en/posts/${post.id.replace(/\.mdoc$/, '')}`} class="block aspect-4/3 bg-neutral-dark relative overflow-hidden">
                {post.data.imagepost ? (
                  <img
                    src={post.data.imagepost}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="absolute inset-0 flex items-center justify-center text-text-inverse/30 text-sm">Image</span>
                )}
              </a>
              <div class="p-5 flex flex-col grow">
                <div class="mb-5">
                  <span class="inline font-sans text-sm font-medium uppercase tracking-wider text-text-primary bg-sky-300 px-2 py-0.5">
                    {post.data.category || 'News'}
                  </span>
                </div>
              <h3 class="font-sans font-bold text-[20px] text-text-primary leading-tight uppercase mb-5 grow">
                  {post.data.title}
                </h3>
                <a href={`/en/posts/${post.id.replace(/\.mdoc$/, '')}`} class="font-sans text-base font-bold  text-fuchsia-600 underline uppercase">
                  {t('common.readMore')}
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="text-center mt-10">
          <a
            href={translatePath('/novedades')}
            class="inline-block font-sans text-caption font-bold uppercase tracking-wider text-text-inverse bg-primary rounded-pill px-8 py-3 no-underline hover:bg-accent-magenta transition-all duration-fast"
          >
            VIEW ALL NEWS
          </a>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <div class="mt-2 md:mt-6">
      <Newsletter decorated />
    </div>
  </main>

  <Footer />
</Layout>
