---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

const t = useTranslations('en');
const translatePath = useTranslatedPath('en');

const posts = await getCollection('posts');
const publicaciones = await getCollection('publicacionesEn');

const tematicas = [
  'Democracia ambiental',
  'Participación ciudadana',
  'Articulación e incidencia',
  'Transparencia y rendición de cuentas',
  'Gobiernos locales',
  'Innovación y tecnología cívica',
  'Educación y garantías democráticas',
];

const noticias = posts
.map((post) => ({
  id: post.id.replace(/\.mdoc$/, ''),
  title: post.data.title,
  subtitle: post.data.subtitle,
  image: post.data.imagepost,
  date: post.data.date,
  tipo: post.data.tipo,
  tematica: post.data.tematica,
  href: `/en/posts/${post.id.replace(/\.mdoc$/, '')}`,
  external: false,
}))
.sort((a, b) => {
  if (!a.date && !b.date) return 0;
  if (!a.date) return 1;
  if (!b.date) return -1;
  return b.date.getTime() - a.date.getTime();
});

const publicacionesItems = publicaciones
  .map((pub) => ({
    id: pub.id.replace(/\.yaml$/, ''),
    title: pub.data.nombre,
    subtitle: pub.data.descripcion,
    image: pub.data.imagen,
    date: undefined,
    tipo: pub.data.tipo,
    tematica: pub.data.tematica,
    order: pub.data.order,
    href: pub.data.link,
    external: true,
    downloadUrl: pub.data.descarga,
  }))
  .sort((a, b) => a.order - b.order);
---

<Layout
  title="News | Ciudadanía Inteligente"
  description="Discover our research, manuals, columns, and newsletters."
>
  <div class="bg-primary">
    <Navbar />
  </div>
  <main>
    <PageHero
      title="News"
      description={`<span class="font-['Work_Sans'] text-white text-2xl font-bold">Discover our research, manuals, columns, and newsletters</span><span class="font-['Work_Sans'] text-lime-300 text-2xl font-medium"> that analyze and propose paths towards a more participatory, fair, and sustainable democracy.</span>`}
      breadcrumb={[
        { label: t('common.breadcrumb.home'), href: translatePath('/') },
        { label: 'News' },
      ]}
    />

    <!-- Noticias Section -->
    <section
      id="news-section"
      class="relative py-16 md:py-20"
      x-data="{
        filtro: '',
        visible: 9,
        allCards: [],
        visibleIndices: new Set(),
        normalize(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); },
        matches(card) {
          if (!this.filtro) return true;
          const filter = this.normalize(this.filtro);
          const tematicas = (card.dataset.tematica || '').split(',').map(t => this.normalize(t));
          return tematicas.includes(filter);
        },
        init() {
          this.allCards = Array.from(this.$refs.grid.querySelectorAll('[data-news-index]'));
          this.updateVisible();
          this.$watch('filtro', () => { this.visible = 9; this.updateVisible(); });
          this.$watch('visible', () => this.updateVisible());
        },
        updateVisible() {
          this.visibleIndices = new Set(
            this.allCards
              .filter(c => this.matches(c))
              .slice(0, this.visible)
              .map(c => parseInt(c.dataset.newsIndex))
          );
        },
        isVisible(card) { return this.visibleIndices.has(parseInt(card.dataset.newsIndex)); },
        loadMore() { this.visible += 9; },
        hasMore() {
          return this.allCards.filter(c => this.matches(c)).length > this.visible;
        }
      }"
      x-init="init()"
    >
      <div class="max-w-300 mx-auto px-6 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary uppercase tracking-wide text-center mb-2 md:mb-8">
          News
        </h2>

        <!-- Filters -->
        <div class="flex flex-wrap items-center justify-center gap-4 mb-10 md:mb-16">
          <span class="text-text-primary text-xl font-bold font-['Work_Sans']">{t('common.filterBy')}</span>
          <select x-model="filtro" class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option value="">{t('common.topic')}</option>
            {tematicas.map((tematica) => (
            <option value={tematica}>{tematica}</option>
            ))}
          </select>
        </div>

        <!-- News Grid -->
        <div x-ref="grid" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
          {noticias.map((item, index) => (
          <article
            class="news-card bg-bg-gray rounded-lg overflow-hidden flex flex-col"
            data-tematica={item.tematica?.join(',') || ''}
            data-news-index={index}
            x-show="isVisible($el)"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-4"
          >
            <a href={item.href} class="block aspect-4/3 bg-neutral-dark relative overflow-hidden">
              {item.image ? (
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
              ) : (
              <span class="absolute inset-0 flex items-center justify-center text-text-inverse/30 text-sm">Image</span>
              )}
            </a>
            <div class="p-5 flex flex-col grow">
              <div class="mb-5">
                <span class="inline font-sans text-sm font-medium uppercase tracking-wider text-text-primary bg-sky-300 px-2 py-0.5">
                  {item.tipo}
                </span>
              </div>
              <h3 class="font-sans font-bold text-[20px] text-text-primary leading-tight uppercase mb-3 grow">
                {item.title}
              </h3>
              {item.tematica && item.tematica.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mb-4">
                {item.tematica.map((t) => (
                <span class="inline-block font-sans text-caption font-semibold uppercase tracking-wide text-primary bg-primary/10 rounded-pill px-2.5 py-0.5">
                  {t}
                </span>
                ))}
              </div>
              )}
              <a href={item.href} class="font-sans text-base font-bold text-fuchsia-600 underline uppercase">
                {t('common.readMore')}
              </a>
            </div>
          </article>
          ))}
        </div>

        <!-- Load More -->
        <div class="flex justify-center mt-10 md:mt-16">
          <button
            type="button"
            x-show="hasMore()"
            @click="loadMore()"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="inline-flex items-center gap-2 font-sans font-bold text-body bg-primary text-text-inverse px-6 py-3 rounded-md shadow-sm hover:bg-accent-magenta transition-colors duration-fast cursor-pointer"
          >
            {t('common.loadMore')}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- Publicaciones Section -->
    <section
      id="publicaciones-section"
      class="relative py-16 md:py-20"
      x-data="{
        filtro: '',
        visible: 9,
        allCards: [],
        visibleIndices: new Set(),
        normalize(s) { return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); },
        matches(card) {
          if (!this.filtro) return true;
          const filter = this.normalize(this.filtro);
          const tematicas = (card.dataset.tematica || '').split(',').map(t => this.normalize(t));
          return tematicas.includes(filter);
        },
        init() {
          this.allCards = Array.from(this.$refs.grid.querySelectorAll('[data-pub-index]'));
          this.updateVisible();
          this.$watch('filtro', () => { this.visible = 9; this.updateVisible(); });
          this.$watch('visible', () => this.updateVisible());
        },
        updateVisible() {
          this.visibleIndices = new Set(
            this.allCards
              .filter(c => this.matches(c))
              .slice(0, this.visible)
              .map(c => parseInt(c.dataset.pubIndex))
          );
        },
        isVisible(card) { return this.visibleIndices.has(parseInt(card.dataset.pubIndex)); },
        loadMore() { this.visible += 9; },
        hasMore() {
          return this.allCards.filter(c => this.matches(c)).length > this.visible;
        }
      }"
      x-init="init()"
    >
      <div class="max-w-300 mx-auto px-6 relative">
        <h2 class="font-sans font-extrabold text-h2 text-text-primary uppercase tracking-wide text-center mb-2 md:mb-8">
          Publications
        </h2>

        <!-- Filters -->
        <div class="flex flex-wrap items-center justify-center gap-4 mb-10 md:mb-16">
          <span class="text-text-primary text-xl font-bold font-['Work_Sans']">{t('common.filterBy')}</span>
          <select x-model="filtro" class="font-sans text-body bg-lime-300 text-black border border-black/10 rounded-md px-4 py-2 cursor-pointer">
            <option value="">{t('common.topic')}</option>
            {tematicas.map((tematica) => (
            <option value={tematica}>{tematica}</option>
            ))}
          </select>
        </div>

        <!-- Publicaciones Grid -->
        <div x-ref="grid" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
          {publicacionesItems.map((item, index) => (
          <article
            class="pub-card relative flex flex-col w-full h-130 md:h-145 max-w-98.5 mx-auto items-center rounded-md bg-bg-default shadow-card overflow-hidden"
            data-tematica={item.tematica.join(',')}
            data-pub-index={index}
            x-show="isVisible($el)"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-4"
          >
            <figure class="pt-4 px-4 shrink-0">
              {item.image ? (
              <img
                src={item.image}
                alt={item.title}
                class="rounded-sm border border-gray-300 max-h-64 w-auto object-contain"
                loading="lazy"
              />
              ) : (
              <div class="w-full h-64 bg-bg-gray flex items-center justify-center rounded-sm">
                <span class="text-text-body/40 text-sm">Image</span>
              </div>
              )}
            </figure>
            <div class="flex flex-col items-center text-center mt-4 mx-6 mb-2 grow">
              <p class="font-['Work_Sans'] text-lg text-text-primary leading-tight">
                {item.title}
              </p>
              {item.tematica.length > 0 && (
              <div class="text-center flex flex-wrap gap-1.5 mt-3">
                {item.tematica.map((t) => (
                <span class="inline-block font-sans text-caption font-semibold uppercase tracking-wide text-primary bg-primary/10 rounded-md px-2.5 py-0.5">
                  {t}
                </span>
                ))}
              </div>
              )}
            </div>
            <a
              href={item.downloadUrl || item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="absolute bottom-4 left-4 right-4 flex items-center justify-between p-3 font-['Work_Sans'] text-sm md:text-body text-accent-magenta border border-accent-magenta rounded-md shadow-sm transition-colors duration-fast hover:bg-primary hover:text-text-inverse hover:border-primary"
              aria-label="Download publication"
            >
              <span>{t('common.downloadPDF')}</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
              </svg>
            </a>
          </article>
          ))}
        </div>

        <!-- Load More -->
        <div class="flex justify-center mt-10 md:mt-16">
          <button
            type="button"
            x-show="hasMore()"
            @click="loadMore()"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="inline-flex items-center gap-2 font-sans font-bold text-body bg-primary text-text-inverse px-6 py-3 rounded-md shadow-sm hover:bg-accent-magenta transition-colors duration-fast cursor-pointer"
          >
            {t('common.loadMore')}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <Newsletter decorated />
  </main>

  <Footer />
</Layout>

<style is:global>
.news-card, .pub-card {
  transition: opacity 250ms ease, transform 250ms ease;
}

@media (min-width: 768px) {
  #news-section .news-card.middle-column {
    margin-top: 2.5rem;
  }
}
</style>
