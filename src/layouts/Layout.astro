---
import '../styles/global.css';
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Ciudadanía Inteligente',
  description = 'Organización latinoamericana sin fines de lucro que impulsa una democracia más participativa, justa y sostenible.',
  ogImage = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://ciudadaniai.org');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <ClientRouter />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700;800;900&family=Geologica:wght@700;900&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body>
    <slot />

    <!-- Alpine.js -->
    <script type="module">
    import Alpine from 'alpinejs';
    window.Alpine = Alpine;
    Alpine.start();

    document.addEventListener('astro:after-swap', () => {
      Alpine.destroyTree(document.body);
      Alpine.initTree(document.body);
    });
    </script>
  </body>
</html>
